# Copiar a .env y completar. NUNCA commitear .env
# --- Django ---
DJANGO_SECRET_KEY=cambiar-por-clave-segura
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,tu-dominio.com

# --- PostgreSQL/PostGIS ---
POSTGRES_DB=geoinsight
POSTGRES_USER=geoinsight
POSTGRES_PASSWORD=cambiar-password-seguro

# --- Google Earth Engine (Service Account) ---
GEE_SERVICE_ACCOUNT=mi-sa@mi-proyecto.iam.gserviceaccount.com
GEE_PRIVATE_KEY_FILE=/credentials/gee-sa-key.json
GEE_PROJECT=mi-proyecto-gcp

# --- LLM (API compatible con OpenAI) ---
# DeepSeek:  LLM_BASE_URL=https://api.deepseek.com  | clave en https://platform.deepseek.com
# OpenAI:    LLM_BASE_URL=https://api.openai.com/v1 | clave en https://platform.openai.com
LLM_API_KEY=sk-...
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
